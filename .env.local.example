# =============================================================================
# .env.local.example — 容器内运行 + 自定义 LLM base_url 的示例配置
#
# 用法:
#   cp .env.local.example .env
#   docker compose run --rm tradingagents
#
# 说明:
#   - docker-compose.yml 通过 env_file 加载 .env，以下变量会注入容器。
#   - TRADINGAGENTS_LLM_BACKEND_URL 是全局单值，作用于当前选定的
#     llm_provider（不是按厂商分别配置）。
#   - 容器内访问宿主机服务时，使用 http://host.docker.internal:<port>
#     （Linux 上需在 compose 中加 extra_hosts: host.docker.internal:host-gateway，
#       或直接用宿主机局域网 IP）。
# =============================================================================

# -----------------------------------------------------------------------------
# 1. 选择 LLM provider 与模型（设置后 CLI 会跳过对应的交互式选择步骤）
#    可选 provider: openai, anthropic, google, xai, deepseek, qwen, qwen-cn,
#                   glm, glm-cn, minimax, minimax-cn, openrouter, ollama, azure
# -----------------------------------------------------------------------------
TRADINGAGENTS_LLM_PROVIDER=openai
TRADINGAGENTS_DEEP_THINK_LLM=gpt-5.5
TRADINGAGENTS_QUICK_THINK_LLM=gpt-5.4-mini

# -----------------------------------------------------------------------------
# 2. 自定义 base_url（核心配置）
#    覆盖所选 provider 的默认 API 端点，指向你的代理/网关/中转服务。
#    留空或注释掉 = 使用各厂商官方端点。
#
#    重要：不要保留占位域名 your-gateway.example.com。复制本文件到 .env 后，
#    如果暂时不用自定义网关，请保持下面这一行注释；需要时再取消注释并改成真实地址。
#
#    示例:
#      OpenAI 兼容网关:   https://your-real-gateway.example.com/v1
#      宿主机上的服务:    http://host.docker.internal:8000/v1
#      one-api / new-api: http://host.docker.internal:3000/v1
#      LM Studio:         http://host.docker.internal:1234/v1
# -----------------------------------------------------------------------------
#TRADINGAGENTS_LLM_BACKEND_URL=

# -----------------------------------------------------------------------------
# 3. API Key（只需设置你所选 provider 对应的那一个；
#    自定义网关也从这里读取，需与网关的鉴权方式兼容）
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
#ANTHROPIC_API_KEY=
#GOOGLE_API_KEY=
#XAI_API_KEY=
#DEEPSEEK_API_KEY=
#DASHSCOPE_API_KEY=
#DASHSCOPE_CN_API_KEY=
#ZHIPU_API_KEY=
#ZHIPU_CN_API_KEY=
#MINIMAX_API_KEY=
#MINIMAX_CN_API_KEY=
#OPENROUTER_API_KEY=

# -----------------------------------------------------------------------------
# 4. Ollama（仅 llm_provider=ollama 时生效；独立于 BACKEND_URL 的覆盖项）
#    docker compose --profile ollama 场景下指向 compose 内的 ollama 服务:
# -----------------------------------------------------------------------------
#OLLAMA_BASE_URL=http://ollama:11434/v1

# -----------------------------------------------------------------------------
# 5. 数据源（可选）
# -----------------------------------------------------------------------------
#ALPHA_VANTAGE_API_KEY=

# -----------------------------------------------------------------------------
# 6. 其他可选覆盖项
# -----------------------------------------------------------------------------
#TRADINGAGENTS_OUTPUT_LANGUAGE=Chinese
#TRADINGAGENTS_MAX_DEBATE_ROUNDS=1
#TRADINGAGENTS_MAX_RISK_ROUNDS=1
#TRADINGAGENTS_CHECKPOINT_ENABLED=false
#TRADINGAGENTS_TEMPERATURE=0.0
#TRADINGAGENTS_RESULTS_DIR=
#TRADINGAGENTS_CACHE_DIR=
#TRADINGAGENTS_MEMORY_LOG_PATH=
# TradingWeb 多管理员账号，格式: 用户名:密码,用户名2:密码2
# 请复制到本地 .env 后改成你自己的强密码，不要提交真实密码。
#TRADINGWEB_USERS=admin:change-me,operator:change-me-too
#TRADINGWEB_SECRET=replace-with-a-long-random-secret
#TRADINGWEB_IMAGE=ghcr.io/osindex/tradingagents-tradingweb:main
